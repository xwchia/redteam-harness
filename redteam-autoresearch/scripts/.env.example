# Copy this file to .red-team/.env in the run workspace and fill in your key.
# The harness loads it via python-dotenv. Never commit your real .env.
#
# This key authenticates the ONLY model the harness calls: the target under test.
# You (the agent running the skill) are the attacker and judge, so no other key is needed.

# Set only the key for the target provider you plan to run.
#
# Default provider: OpenRouter -- one key, many models selected by id.
OPENROUTER_API_KEY=

# Alternative OpenAI-compatible target providers (uncomment and set as needed).
# MOONSHOT_API_KEY=
# FIREWORKS_API_KEY=
# UBICLOUD_API_KEY=
# OPENAI_API_KEY=
